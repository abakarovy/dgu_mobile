# Локально (uvicorn --port 8000):
# API_BASE_URL=http://192.168.42.45:8000/api
#
# Продакшен:
# API_BASE_URL=https://college.dgu.ru/api
#
API_BASE_URL=http://192.168.42.45:8000/api

# Мок-бэкенд (lib/moc, MockDioInterceptor): ответы API без сети.
# Включить: true | 1 | yes — выключить: false | 0 | no — реальные запросы к API_BASE_URL.
# Если строки нет в .env — действует --dart-define=USE_MOCK_BACKEND (по умолчанию true).
USE_MOCK_BACKEND=true
