# Пример конфигурации. Скопируйте этот файл как `assets/env/.env` и укажите свой API.
# Example config. Copy to `assets/env/.env` and set your backend URL.
#
# Android emulator → host machine:
# API_BASE_URL=http://10.0.2.2:8000/api
#
# iOS simulator / localhost:
# API_BASE_URL=http://127.0.0.1:8000/api
#
API_BASE_URL=http://10.0.2.2:8000/api
